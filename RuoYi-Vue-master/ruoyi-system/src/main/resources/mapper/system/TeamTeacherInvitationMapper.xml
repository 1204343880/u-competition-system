<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.TeamTeacherInvitationMapper">

    <resultMap type="TeamTeacherInvitation" id="InvitationResult">
        <result property="invitationId"    column="invitation_id"    />
        <result property="teamId"          column="team_id"          />
        <result property="competitionId"   column="competition_id"   />
        <result property="teacherId"       column="teacher_id"       />
        <result property="teacherName"     column="teacher_name"     />
        <result property="studentId"       column="student_id"       />
        <result property="studentName"     column="student_name"     />
        <result property="teamName"        column="team_name"        />
        <result property="competitionName" column="competition_name" />
        <result property="status"          column="status"           />
        <result property="replyMessage"    column="reply_message"    />
        <result property="createTime"      column="create_time"      />
        <result property="updateTime"      column="update_time"      />
    </resultMap>

    <sql id="selectVo">
        select invitation_id, team_id, competition_id, teacher_id, teacher_name,
               student_id, student_name, team_name, competition_name,
               status, reply_message, create_time, update_time
        from team_teacher_invitation
    </sql>

    <select id="selectInvitationById" parameterType="Long" resultMap="InvitationResult">
        <include refid="selectVo"/> where invitation_id = #{invitationId}
    </select>

    <select id="selectInvitationsByTeamId" parameterType="Long" resultMap="InvitationResult">
        <include refid="selectVo"/> where team_id = #{teamId} order by create_time desc
    </select>

    <select id="selectPendingByTeacherId" parameterType="Long" resultMap="InvitationResult">
        <include refid="selectVo"/> where teacher_id = #{teacherId} and status = '0' order by create_time desc
    </select>

    <select id="selectHistoryByTeacherId" parameterType="Long" resultMap="InvitationResult">
        <include refid="selectVo"/> where teacher_id = #{teacherId} and status != '0' order by update_time desc
    </select>

    <insert id="insertInvitation" parameterType="TeamTeacherInvitation" useGeneratedKeys="true" keyProperty="invitationId">
        insert into team_teacher_invitation
        (team_id, competition_id, teacher_id, teacher_name, student_id, student_name, team_name, competition_name, status, create_time)
        values (#{teamId}, #{competitionId}, #{teacherId}, #{teacherName}, #{studentId}, #{studentName}, #{teamName}, #{competitionName}, '0', #{createTime})
    </insert>

    <update id="updateStatus" parameterType="TeamTeacherInvitation">
        update team_teacher_invitation
        set status = #{status}, reply_message = #{replyMessage}, update_time = #{updateTime}
        where invitation_id = #{invitationId}
          and status = '0'
    </update>

    <delete id="deleteInvitation" parameterType="Long">
        delete from team_teacher_invitation where invitation_id = #{invitationId}
    </delete>

</mapper>
