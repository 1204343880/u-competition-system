FROM nginx:alpine

COPY nginx/nginx.conf /etc/nginx/nginx.conf
COPY innotrack-ui/dist /usr/share/nginx/html

RUN test -f /usr/share/nginx/html/50x.html || \
    printf '%s\n' '<!doctype html><html><head><meta charset="utf-8"><title>Service Unavailable</title></head><body><h1>Service Unavailable</h1></body></html>' \
    > /usr/share/nginx/html/50x.html

EXPOSE 80
